# SQLite generada por slack-automatizacion
SOURCE_DB_PATH=../slack-automatizacion/slack_agent.db
# DB propia del worker
WORKER_DB_PATH=salesforce_report_agent.db
# Artifacts
ARTIFACTS_DIR=artifacts
# Mapping manual opcional
FIELD_MAPPING_PATH=
# Ollama
MODEL_PROVIDER=ollama
OLLAMA_MODEL=gemma4:e2b-mlx
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TEMPERATURE=0
# Salesforce auth (read-only). Recomendado para organizaciones con MFA.
SALESFORCE_AUTH_MODE=oauth
# Password mode legacy
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
# OAuth mode
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=http://localhost:8765/callback
SALESFORCE_REFRESH_TOKEN=
SALESFORCE_ACCESS_TOKEN=
SALESFORCE_INSTANCE_URL=
SALESFORCE_TOKEN_PATH=.salesforce_token.json
SALESFORCE_DOMAIN=login
# Seguridad
SF_READ_ONLY=true
MAX_EXPORT_ROWS=50000
REQUIRE_HUMAN_APPROVAL_FOR_PII=true
ALLOW_REPORT_WITHOUT_PERSON_FIELDS=false
LOG_PII=false
UPDATE_SOURCE_TASK=false
